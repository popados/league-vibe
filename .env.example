# League Vibe Environment Configuration
# ===================================

# Riot Games API Key
# Get your free API key from: https://developer.riotgames.com/
# Replace 'your_riot_api_key_here' with your actual API key
RIOT_API_KEY=your_riot_api_key_here

# MongoDB Connection String
# Replace with your MongoDB connection URI
MONGODB_URI=your_mongodb_connection_uri

# Optional: MongoDB Configuration
# MONGODB_DB_NAME=league-vibe
# MONGODB_MATCH_HISTORY_COLLECTION=matchHistories

# Optional: Server Configuration
# PORT=3001